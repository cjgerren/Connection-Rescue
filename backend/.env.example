# ConnectionRescue backend — environment template
# Copy to backend/.env and fill in. NEVER commit the real .env.

# ---- Server ----
PORT=8787
# Comma-separated list of allowed origins for CORS (the React app).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Flight status / rescue guidance ----
# https://aviationstack.com/
AVIATIONSTACK_API_KEY=aviationstack_xxx

# ---- Stripe (real payments) ----
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_APP_NAME=ConnectionRescue
# Created when you `stripe listen` or in dashboard webhook settings.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Service fee charged on every rescue booking, in cents.
RESCUE_SERVICE_FEE_CENTS=1499

# ---- Supabase (server-side / service role) ----
# Found in Supabase project > Settings > API.
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# Used to validate JWTs the React app sends in the Authorization header.
SUPABASE_ANON_KEY=eyJhbGci...

# ---- Frontend ----
# Where to redirect users after Stripe Checkout completes / cancels.
FRONTEND_URL=http://localhost:5173
